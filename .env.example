# Required
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Optional AI provider configuration (required only for AI Q&A and embeddings)
OPENAI_API_KEY=
DOCPILOT_AI_MODEL=gpt-4o-mini
DOCPILOT_EMBEDDING_MODEL=text-embedding-3-small

# Optional API/Frontend ports on host
BACKEND_PORT=8000
FRONTEND_PORT=5500

# Optional PostgreSQL local defaults for Docker Compose
POSTGRES_DB=docpilot
POSTGRES_USER=docpilot
POSTGRES_PASSWORD=docpilot_local_password

# Optional retrieval and evaluation tuning
DOCPILOT_EMBEDDING_BATCH_SIZE=100
DOCPILOT_RETRIEVAL_TOP_K=5
DOCPILOT_RETRIEVAL_MIN_SCORE=0.0
DOCPILOT_EVAL_MAX_LATENCY_MS=5000.0
DOCPILOT_EVAL_MIN_CONTEXT_REDUCTION=50.0
DOCPILOT_EVAL_MIN_CITATION_PRESERVATION=0.8
DOCPILOT_EVAL_PERSIST_RESULTS=true
DOCPILOT_CONVERSATION_MAX_MESSAGES=10
