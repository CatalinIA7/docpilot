# Required
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Optional AI provider configuration (required only for AI Q&A and embeddings)
OPENAI_API_KEY=
DOCPILOT_AI_MODEL=gpt-4o-mini
DOCPILOT_EMBEDDING_MODEL=text-embedding-3-small

# Optional API/Frontend ports on host
BACKEND_PORT=8000
FRONTEND_PORT=5500

# Browser-facing service configuration
DOCPILOT_API_URL=http://127.0.0.1:8000
DOCPILOT_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null

# Security defaults (production uses exact HTTPS origins/hosts and enables limits)
DOCPILOT_ENVIRONMENT=development
DOCPILOT_TRUSTED_HOSTS=localhost,127.0.0.1
DOCPILOT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
DOCPILOT_MAX_REQUEST_SIZE=11534336
DOCPILOT_MAX_DOCX_UNCOMPRESSED_SIZE=52428800
DOCPILOT_MAX_DOCX_ENTRIES=2000
DOCPILOT_RATE_LIMIT_ENABLED=false
DOCPILOT_AUTH_RATE_LIMIT_PER_MINUTE=20
DOCPILOT_UPLOAD_RATE_LIMIT_PER_MINUTE=10
DOCPILOT_AI_RATE_LIMIT_PER_MINUTE=30

# Optional backend upload path override (Compose defaults to /app/uploads)
# DOCPILOT_UPLOAD_DIR=/absolute/path/to/uploads

# Optional PostgreSQL local defaults for Docker Compose
POSTGRES_DB=docpilot
POSTGRES_USER=docpilot
POSTGRES_PASSWORD=docpilot_local_password

# Optional retrieval and evaluation tuning
DOCPILOT_EMBEDDING_BATCH_SIZE=100
DOCPILOT_RETRIEVAL_TOP_K=5
DOCPILOT_RETRIEVAL_MIN_SCORE=0.0
DOCPILOT_EVAL_MAX_LATENCY_MS=5000.0
DOCPILOT_EVAL_MIN_CONTEXT_REDUCTION=50.0
DOCPILOT_EVAL_MIN_CITATION_PRESERVATION=0.8
DOCPILOT_EVAL_PERSIST_RESULTS=true
DOCPILOT_CONVERSATION_MAX_MESSAGES=10

# Operational logging
DOCPILOT_LOG_LEVEL=INFO
DOCPILOT_LOG_FORMAT=json
DOCPILOT_SLOW_QUERY_MS=250
